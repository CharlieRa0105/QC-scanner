# Python
__pycache__/
*.pyc
.venv/
.venv312/
.pytest_cache/

# PyInstaller / desktop-build artifacts (the console is a web app, not a binary)
build/
dist/

# OS
.DS_Store

# Arm SDK runtime logs
_rokae_log_/
logs/

# Site-specific config + CAD (local only) — repo-root config/ ONLY.
# Anchored with a leading slash so it does NOT swallow ROS package config dirs
# (e.g. ros2_ws/src/qc_moveit_config/config/, which holds tracked MoveIt config).
/config/

# Generated planner / viewer artifacts (regenerated by the app + scripts;
# data/scans.json is the results store and IS tracked)
data/scanpath.json
data/scanpath_arm.json
data/viewer_bundle.json
data/_plan_part.json

# ROS 2 colcon workspace build artifacts (regenerated by colcon build)
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# Vendor driver clone — has its own .git; a dependency, re-cloned by docker/build.sh
ros2_ws/src/rokae_ros2/
